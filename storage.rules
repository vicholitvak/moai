rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Dish images: only the cooker who owns the dish can upload/delete.
    // The path is structured as dishes/{cookerId}/{dishImageId}/{fileName}
    match /dishes/{cookerId}/{dishImageId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == cookerId;
    }
  }
}